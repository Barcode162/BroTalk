{
  "name": "brotalk",
  "productName": "BroTalk",
  "version": "0.3.3",
  "description": "Peer-to-peer voice chat for friends and family",
  "main": "main.js",
  "type": "commonjs",
  "author": "Barcode162",
  "license": "ISC",
  "scripts": {
    "start": "node server.js",
    "app": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.3.9",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.barcode162.brotalk",
    "productName": "BroTalk",
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "!public/splash.html",
      "!public/splash.css",
      "!public/splash.js",
      "!public/brotalk-annotated.css",
      "node_modules/**/*",
      "!server.js",
      "!render.yaml",
      "!README.md"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BroTalk",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Barcode162",
      "repo": "BroTalk",
      "releaseType": "release"
    }
  }
}
